# --- Required: LLM + embeddings -------------------------------------------
# Anthropic Claude is used for extraction and contradiction/merge decisions.
ANTHROPIC_API_KEY=

# Voyage AI is used for embeddings (model: voyage-4-lite, 1024 dims).
VOYAGE_API_KEY=

# --- Database (defaults match docker-compose.yml) -------------------------
# Inside docker-compose, the api service reaches Postgres at host "db".
# Override DATABASE_URL only if running the api outside compose.
DATABASE_URL=postgresql://memory:memory@db:5432/memory

# --- Optional: bearer-token auth ------------------------------------------
# If set, every endpoint except GET /health requires
#   Authorization: Bearer <token>
# If unset (default), the Authorization header is ignored.
MEMORY_AUTH_TOKEN=

# --- Optional: model overrides --------------------------------------------
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
VOYAGE_EMBED_MODEL=voyage-4-lite
VOYAGE_EMBED_DIM=1024

# --- Optional: server tuning ----------------------------------------------
LOG_LEVEL=INFO
